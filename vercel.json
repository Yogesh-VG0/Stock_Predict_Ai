{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "$NODE_BACKEND_URL/api/auth/:path*" },
    { "source": "/api/news/:path*", "destination": "$NODE_BACKEND_URL/api/news/:path*" },
    { "source": "/api/stock/:path*", "destination": "$NODE_BACKEND_URL/api/stock/:path*" },
    { "source": "/api/watchlist/:path*", "destination": "$NODE_BACKEND_URL/api/watchlist/:path*" },
    { "source": "/api/market/:path*", "destination": "$NODE_BACKEND_URL/api/market/:path*" },
    { "source": "/api/notifications/:path*", "destination": "$NODE_BACKEND_URL/api/notifications/:path*" },
    { "source": "/api/v1/:path*", "destination": "$NODE_BACKEND_URL/api/v1/:path*" }
  ]
}
